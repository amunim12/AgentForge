# ============================================
# APP SETTINGS
# ============================================
APP_NAME=AgentForge
DEBUG=false
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# LLM API KEYS (ALL FREE TIER)
# ============================================
# Google AI Studio: https://aistudio.google.com
GOOGLE_API_KEY=

# Groq Console: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key

# Tavily: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key

# E2B Code Sandbox: https://e2b.dev
E2B_API_KEY=e2b_your-e2b-api-key

# LangSmith: https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
# LangChain SDK reads LANGCHAIN_API_KEY; set to the same value as LANGSMITH_API_KEY
LANGCHAIN_API_KEY=
LANGSMITH_PROJECT="AgentForge"

# ============================================
# INFRASTRUCTURE
# ============================================
# Upstash Redis: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./agentforge.db

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
# Optional: set a bearer token to enable ChromaDB authentication
CHROMA_AUTH_TOKEN=

# ============================================
# SECURITY
# ============================================
# JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ============================================
# AGENT CONFIG
# ============================================
MAX_CRITIC_ITERATIONS=3
CRITIC_SCORE_THRESHOLD=0.75
MAX_TOKENS_PER_AGENT=4096
MAX_AGENT_ITERATIONS=15

# ============================================
# DATABASE POOL (ignored for SQLite)
# ============================================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
